# Copy this file to .env and fill in real values. Never commit the real .env file.

# Required — signs session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=

# Required for the AI document review endpoint to work. Get one from
# https://console.anthropic.com/ — keep this secret, never put it in
# front-end code.
ANTHROPIC_API_KEY=

# Optional — which Claude model reviews documents. Defaults to claude-sonnet-5.
# Use claude-haiku-4-5-20251001 for lower cost at higher volume.
ANTHROPIC_MODEL=claude-sonnet-5

# Seeds the first admin account on first run (only used if no admin exists yet).
# Change the password immediately after first login in a real deployment.
ADMIN_EMAIL=admin@anyvisa.co.uk
ADMIN_PASSWORD=changeme-immediately

# Restrict CORS to your real site once you know the URL, e.g.:
#   ALLOWED_ORIGIN=https://yourusername.github.io
# Defaults to "*" (any origin) if unset — fine for local testing only.
ALLOWED_ORIGIN=*

# Port the server listens on.
PORT=3000

# Where the SQLite database file is stored. Defaults to ./data/anyvisa.db
# DB_PATH=./data/anyvisa.db
